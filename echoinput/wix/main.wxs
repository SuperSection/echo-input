<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="EchoInput"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Language="1033"
    Codepage="1252"
    Version="$(var.Version)"
    Manufacturer="EchoInput Team">

    <Package
      Id="*"
      Keywords="Installer"
      Description="EchoInput keyboard visualization overlay"
      Manufacturer="EchoInput Team"
      InstallerVersion="200"
      Languages="1033"
      Compressed="yes"
      InstallScope="perMachine"
      SummaryCodepage="1252" />

    <MajorUpgrade
      AllowDowngrades="no"
      DowngradeErrorMessage="A newer version of EchoInput is already installed." />

    <Media Id="1" Cabinet="echoinput.cab" EmbedCab="yes" />
    <Property Id="DiskPrompt" Value="EchoInput Installation" />

    <Icon Id="EchoInputIcon" SourceFile="$(var.CargoTargetBinDir)\echoinput.exe" />
    <Property Id="ARPPRODUCTICON" Value="EchoInputIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/SuperSection/echoinput" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/SuperSection/echoinput" />
    <Property Id="ARPREADME" Value="https://github.com/SuperSection/echoinput" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder" Name="PFiles">
        <Directory Id="APPLICATIONFOLDER" Name="EchoInput">
          <Component Id="MainExecutable" Guid="*" Win64="yes">
            <File
              Id="echoinput.exe"
              Name="echoinput.exe"
              DiskId="1"
              Source="$(var.CargoTargetBinDir)\echoinput.exe"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder" Name="Programs">
        <Component Id="Shortcut" Guid="*" Win64="no">
          <CreateFolder Directory="ApplicationProgramsFolder" />
          <Shortcut
            Id="ApplicationStartMenuShortcut"
            Directory="ApplicationProgramsFolder"
            Name="EchoInput"
            Description="Privacy-first keyboard visualization overlay"
            Target="[APPLICATIONFOLDER]echoinput.exe"
            WorkingDirectory="APPLICATIONFOLDER"
            Icon="EchoInputIcon" />
          <RemoveFolder
            Id="RemoveApplicationProgramsFolder"
            Directory="ApplicationProgramsFolder"
            On="uninstall" />
          <RegistryValue
            Root="HKCU"
            Key="Software\EchoInput\Shortcuts"
            Name="StartMenu"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        </Component>
      </Directory>
    </Directory>

    <Feature
      Id="MainProgram"
      Title="EchoInput"
      Description="Installs EchoInput keyboard overlay."
      Level="1"
      ConfigurableDirectory="APPLICATIONFOLDER"
      AllowAdvertise="no"
      Display="hidden"
      Absent="disallow">

      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="Shortcut" />
    </Feature>
  </Product>
</Wix>
